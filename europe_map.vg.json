{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Europe & Surrounding",
    "color": "#ffffff",
    "fontSize": 20,
    "anchor": "start",
    "offset": 15
  },
  "width": "container",
  "height": 500,
  "autosize": {
    "type": "fit",
    "contains": "padding",
    "resize": true
  },
  "params": [
    {
      "name": "selected_country",
      "value": "All",
      "bind": {
        "input": "select",
        "options": [
          "All",
          "Sweden",
          "Ukraine",
          "Norway",
          "Israel",
          "Bulgaria",
          "Cyprus",
          "Lithuania",
          "Serbia",
          "Hungary",
          "Russia",
          "Greece",
          "Armenia",
          "Australia",
          "Luxembourg",
          "Portugal",
          "Austria",
          "Netherlands",
          "Estonia",
          "Albania",
          "Belgium",
          "Finland",
          "Poland",
          "Moldova",
          "Azerbaijan",
          "Czechia",
          "Switzerland",
          "Slovenia",
          "Croatia",
          "Romania",
          "Denmark",
          "Malta",
          "Iceland",
          "Belarus",
          "Latvia",
          "Georgia",
          "San Marino",
          "Ireland",
          "North Macedonia",
          "Montenegro",
          "Bosnia & Herzegovina",
          "Serbia & Montenegro",
          "Turkey",
          "Andorra",
          "Monaco",
          "Slovakia",
          "United Kingdom",
          "France",
          "Germany",
          "Italy",
          "Spain"
        ],
        "name": "Select Countries:"
      }
    },
    {
      "name": "country_data",
      "value": {
        "Sweden": {"center": [18.6, 60.1], "scale": 1000},
        "Ukraine": {"center": [31.2, 48.4], "scale": 1000},
        "Norway": {"center": [8.5, 62.0], "scale": 1000},
        "Israel": {"center": [34.8, 31.0], "scale": 1500},
        "Bulgaria": {"center": [25.5, 42.7], "scale": 1000},
        "Cyprus": {"center": [33.4, 35.1], "scale": 3000},
        "Lithuania": {"center": [23.9, 55.2], "scale": 1000},
        "Serbia": {"center": [21.0, 44.0], "scale": 1000},
        "Hungary": {"center": [19.5, 47.2], "scale": 1000},
        "Russia": {"center": [60.0, 60.0], "scale": 160},
        "Greece": {"center": [21.8, 39.0], "scale": 1000},
        "Armenia": {"center": [45.0, 40.1], "scale": 1000},
        "Australia": {"center": [133.0, -27.0], "scale": 400},
        "Luxembourg": {"center": [6.1, 49.8], "scale": 4000},
        "Portugal": {"center": [-8.2, 39.4], "scale": 1000},
        "Austria": {"center": [14.1, 47.6], "scale": 1000},
        "Netherlands": {"center": [5.3, 52.1], "scale": 1800},
        "Estonia": {"center": [25.0, 58.6], "scale": 1000},
        "Albania": {"center": [20.2, 41.1], "scale": 1000},
        "Belgium": {"center": [4.5, 50.5], "scale": 2000},
        "Finland": {"center": [25.7, 61.9], "scale": 1000},
        "Poland": {"center": [19.1, 52.2], "scale": 1000},
        "Moldova": {"center": [28.4, 47.4], "scale": 1000},
        "Azerbaijan": {"center": [47.5, 40.1], "scale": 1000},
        "Czechia": {"center": [15.5, 49.8], "scale": 1000},
        "Switzerland": {"center": [8.2, 46.8], "scale": 2200},
        "Slovenia": {"center": [15.0, 46.1], "scale": 2500},
        "Croatia": {"center": [15.2, 45.1], "scale": 1000},
        "Romania": {"center": [25.0, 45.9], "scale": 1000},
        "Denmark": {"center": [9.5, 56.2], "scale": 1000},
        "Malta": {"center": [14.4, 35.9], "scale": 5000},
        "Iceland": {"center": [-19.0, 64.9], "scale": 1000},
        "Belarus": {"center": [28.0, 53.7], "scale": 1000},
        "Latvia": {"center": [24.6, 56.9], "scale": 1000},
        "Georgia": {"center": [43.5, 42.3], "scale": 1000},
        "San Marino": {"center": [12.45, 43.94], "scale": 6000},
        "Ireland": {"center": [-8.2, 53.4], "scale": 1000},
        "North Macedonia": {"center": [21.7, 41.6], "scale": 1000},
        "Montenegro": {"center": [19.3, 42.7], "scale": 3000},
        "Bosnia & Herzegovina": {"center": [17.8, 43.9], "scale": 1000},
        "Serbia & Montenegro": {"center": [21.0, 43.5], "scale": 1000},
        "Turkey": {"center": [35.2, 39.0], "scale": 1000},
        "Andorra": {"center": [1.5, 42.5], "scale": 5000},
        "Monaco": {"center": [7.42, 43.73], "scale": 6000},
        "Slovakia": {"center": [19.7, 48.7], "scale": 1000},
        "United Kingdom": {"center": [-2.0, 54.5], "scale": 1000},
        "France": {"center": [2.2, 46.2], "scale": 1000},
        "Germany": {"center": [10.4, 51.1], "scale": 1000},
        "Italy": {"center": [12.5, 41.9], "scale": 1000},
        "Spain": {"center": [-3.7, 40.4], "scale": 1000}
      }
    }
  ],
  "projection": {
    "type": "mercator",
    "scale": {
      "expr": "selected_country == 'All' ? 240 : country_data[selected_country].scale"
    },
    "center": {
      "expr": "selected_country == 'All' ? [16, 54] : country_data[selected_country].center"
    }
  },
  "layer": [
    {
      "data": {
        "url": "data/Eurovision&surrounding.json",
        "format": {
          "type": "topojson",
          "feature": "World_Countries_Generalized"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#333333",
        "stroke": "#161616",
        "strokeWidth": 0.5,
        "clip": true
      }
    },
    {
      "data": {
        "url": "data/Eurovision&surrounding.json",
        "format": {
          "type": "topojson",
          "feature": "World_Countries_Generalized"
        }
      },
      "transform": [
        {
          "calculate": "datum.properties.COUNTRYAFF == 'Russian Federation' ? 'Russia' : datum.properties.COUNTRYAFF == 'Moldova, Republic of' ? 'Moldova' : datum.properties.COUNTRYAFF == 'Bosnia and Herzegovina' ? 'Bosnia & Herzegovina' : datum.properties.COUNTRYAFF",
          "as": "Cleaned_Country"
        },
        {
          "filter": "selected_country == 'All' || datum.Cleaned_Country == selected_country"
        },
        {
          "lookup": "Cleaned_Country",
          "from": {
            "data": {
              "url": "data/qualification_rate.csv"
            },
            "key": "Country",
            "fields": ["Qualifing for F (%)", "Participations SF", "Qualifing for F"]
          }
        },
        {
          "filter": "datum['Qualifing for F (%)'] != null && datum['Qualifing for F (%)'] !== '' && parseFloat(datum['Qualifing for F (%)']) > 0"
        },
        {
          "calculate": "parseFloat(datum['Qualifing for F (%)'])",
          "as": "Qualification_Rate"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#161616",
        "strokeWidth": 0.5,
        "clip": true
      },
      "encoding": {
        "color": {
          "field": "Qualification_Rate",
          "type": "quantitative",
          "scale": {
            "scheme": "blues"
          },
          "legend": {
            "title": "Qualification Rate (%)",
            "format": ".0f",
            "titleColor": "#ffffff",
            "labelColor": "#aaaaaa",
            "orient": "left",
            "offset": 15
          }
        },
        "tooltip": [
          {"field": "Cleaned_Country", "type": "nominal", "title": "Country"},
          {"field": "Qualifing for F (%)", "type": "nominal", "title": "Rate"},
          {"field": "Participations SF", "type": "quantitative", "title": "SF Participations"},
          {"field": "Qualifing for F", "type": "quantitative", "title": "Finals Reached"}
        ]
      }
    },
    {
      "data": {
        "url": "data/Eurovision&surrounding.json",
        "format": {
          "type": "topojson",
          "feature": "World_Countries_Generalized"
        }
      },
      "transform": [
        {
          "filter": "indexof(['United Kingdom', 'France', 'Germany', 'Italy', 'Spain'], datum.properties.COUNTRYAFF) >= 0"
        },
        {
          "calculate": "datum.properties.COUNTRYAFF",
          "as": "Country_Label"
        },
        {
          "calculate": "'Big 5 — Auto-qualifies for the Grand Final'",
          "as": "Status"
        },
        {
          "filter": "selected_country == 'All' || datum.Country_Label == selected_country"
        }
      ],
      "mark": {
        "type": "geoshape",
        "fill": "#f5c842",
        "stroke": null,
        "strokeWidth": 0,
        "clip": true
      },
      "encoding": {
        "tooltip": [
          {"field": "Country_Label", "type": "nominal", "title": "Country"},
          {"field": "Status", "type": "nominal", "title": "Status"}
        ]
      }
    },
    {
      "data": {
        "url": "data/hosting_locations.csv"
      },
      "transform": [
        {
          "aggregate": [{"op": "count", "as": "Hosting_Count"}],
          "groupby": ["Location", "lat", "lon"]
        }
      ],
      "mark": {
        "type": "circle",
        "color": "#ff4081",
        "opacity": 0.8,
        "stroke": "#ffffff",
        "strokeWidth": 1,
        "strokeOpacity": 0.9,
        "clip": true
      },
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "size": {
          "field": "Hosting_Count",
          "type": "quantitative",
          "title": "Times Hosted",
          "scale": {"domain": [1, 6], "range": [30, 180]},
          "legend": {
            "titleColor": "#ffffff",
            "labelColor": "#aaaaaa",
            "orient": "left",
            "offset": 15
          }
        },
        "tooltip": [
          {"field": "Location", "type": "nominal", "title": "Host City"},
          {"field": "Hosting_Count", "type": "quantitative", "title": "Times Hosted"}
        ]
      }
    }
  ],
  "config": {
    "background": "transparent",
    "view": {"stroke": "transparent"},
    "bind": "container"
  }
}